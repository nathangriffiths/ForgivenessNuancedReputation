    java -classpath .:./bin:./lib/commons-cli-1.5.0/commons-cli-1.5.0.jar Simulation -g 100000 -n 100 -m 500 -q 0.8 -is 10 -ea ${i} -ep ${i} -fr -quiet -data num-interactions-fr &
